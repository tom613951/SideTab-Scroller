<Window x:Class="SideTabScroller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SideTabScroller"
        mc:Ignorable="d"
        Title="侧栏滚轮切换标签"
        Height="720"
        Width="980"
        MinHeight="640"
        MinWidth="860"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        Icon="Assets/app.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#FFFFFF"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,0,0,1"
                Padding="32,24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="侧栏滚轮切换标签"
                               FontSize="30"
                               FontWeight="SemiBold" />
                    <TextBlock Text="在 Edge / Chrome 侧边标签栏上滚动鼠标滚轮即可切换标签页"
                               Foreground="{StaticResource MutedInkBrush}"
                               FontSize="14"
                               Margin="1,6,0,0" />
                </StackPanel>
                <CheckBox x:Name="EnabledSwitch"
                          Grid.Column="1"
                          Style="{StaticResource SwitchCheckBoxStyle}"
                          VerticalAlignment="Center"
                          Checked="SettingsControl_Changed"
                          Unchecked="SettingsControl_Changed"
                          Content="已启用" />
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="32,28,32,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.25*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource SectionPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="感应区域"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="侧边栏位置"
                                       Foreground="{StaticResource MutedInkBrush}"
                                       Margin="0,18,0,8" />
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="SidebarAutoRadio"
                                             GroupName="SidebarSide"
                                             Content="自动"
                                             Style="{StaticResource SegmentRadioStyle}"
                                             Checked="SideRadio_Checked" />
                                <RadioButton x:Name="SidebarLeftRadio"
                                             GroupName="SidebarSide"
                                             Content="左侧"
                                             Style="{StaticResource SegmentRadioStyle}"
                                             Checked="SideRadio_Checked" />
                                <RadioButton x:Name="SidebarRightRadio"
                                             GroupName="SidebarSide"
                                             Content="右侧"
                                             Style="{StaticResource SegmentRadioStyle}"
                                             Checked="SideRadio_Checked" />
                            </StackPanel>

                            <Grid Margin="0,24,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="侧边栏宽度" Foreground="{StaticResource MutedInkBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ElementName=SidebarWidthSlider, Path=Value, StringFormat={}{0:0}px}"
                                           Foreground="{StaticResource MutedInkBrush}" />
                            </Grid>
                            <Slider x:Name="SidebarWidthSlider"
                                    Minimum="48"
                                    Maximum="260"
                                    TickFrequency="4"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="SettingsControl_Changed" />

                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="顶部避让" Foreground="{StaticResource MutedInkBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ElementName=TopInsetSlider, Path=Value, StringFormat={}{0:0}px}"
                                           Foreground="{StaticResource MutedInkBrush}" />
                            </Grid>
                            <Slider x:Name="TopInsetSlider"
                                    Minimum="0"
                                    Maximum="180"
                                    TickFrequency="2"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="SettingsControl_Changed" />

                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="底部避让" Foreground="{StaticResource MutedInkBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ElementName=BottomInsetSlider, Path=Value, StringFormat={}{0:0}px}"
                                           Foreground="{StaticResource MutedInkBrush}" />
                            </Grid>
                            <Slider x:Name="BottomInsetSlider"
                                    Minimum="0"
                                    Maximum="120"
                                    TickFrequency="2"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="SettingsControl_Changed" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="行为"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,18" />
                            <CheckBox x:Name="ReverseSwitch"
                                      Content="反转滚动方向"
                                      Style="{StaticResource SwitchCheckBoxStyle}"
                                      Checked="SettingsControl_Changed"
                                      Unchecked="SettingsControl_Changed" />
                            <CheckBox x:Name="SwallowWheelSwitch"
                                      Content="拦截已处理的滚轮事件"
                                      Style="{StaticResource SwitchCheckBoxStyle}"
                                      Checked="SettingsControl_Changed"
                                      Unchecked="SettingsControl_Changed" />
                            <CheckBox x:Name="IgnoreModifiersSwitch"
                                      Content="按住 Ctrl / Alt / Shift / Win 时忽略滚轮"
                                      Style="{StaticResource SwitchCheckBoxStyle}"
                                      Checked="SettingsControl_Changed"
                                      Unchecked="SettingsControl_Changed" />
                            <CheckBox x:Name="AutofocusSwitch"
                                      Content="自动聚焦浏览器窗口"
                                      Style="{StaticResource SwitchCheckBoxStyle}"
                                      Checked="SettingsControl_Changed"
                                      Unchecked="SettingsControl_Changed" />
                            <CheckBox x:Name="RestoreFocusSwitch"
                                      Content="切换后恢复原窗口焦点"
                                      Style="{StaticResource SwitchCheckBoxStyle}"
                                      Checked="SettingsControl_Changed"
                                      Unchecked="SettingsControl_Changed" />

                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="聚焦等待" Foreground="{StaticResource MutedInkBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ElementName=FocusDelaySlider, Path=Value, StringFormat={}{0:0}ms}"
                                           Foreground="{StaticResource MutedInkBrush}" />
                            </Grid>
                            <Slider x:Name="FocusDelaySlider"
                                    Minimum="0"
                                    Maximum="120"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="SettingsControl_Changed" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource SectionPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="浏览器进程"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBox x:Name="BrowserProcessesBox"
                                     Margin="0,18,0,0"
                                     MinHeight="96"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     BorderBrush="{StaticResource LineBrush}"
                                     Padding="12"
                                     TextChanged="BrowserProcessesBox_TextChanged" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="开机启动"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,18" />
                            <CheckBox x:Name="StartupSwitch"
                                      Content="登录 Windows 后自动运行"
                                      Style="{StaticResource SwitchCheckBoxStyle}"
                                      Checked="StartupSwitch_Changed"
                                      Unchecked="StartupSwitch_Changed" />
                            <TextBlock x:Name="StartupStatusText"
                                       Foreground="{StaticResource MutedInkBrush}"
                                       FontSize="13" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="状态"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="StatusText"
                                       Margin="0,16,0,0"
                                       Foreground="{StaticResource MutedInkBrush}" />
                            <TextBlock x:Name="LastActionText"
                                       Margin="0,10,0,0"
                                       Foreground="{StaticResource MutedInkBrush}" />
                            <TextBlock x:Name="ConfigPathText"
                                       Margin="0,10,0,0"
                                       Foreground="{StaticResource MutedInkBrush}" />
                            <WrapPanel Margin="0,22,0,0">
                                <Button Content="打开配置"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,10,10"
                                        Click="OpenConfigButton_Click" />
                                <Button Content="重置"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,10,10"
                                        Click="ResetButton_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
