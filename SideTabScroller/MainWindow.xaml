<Window x:Class="SideTabScroller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SideTabScroller"
        mc:Ignorable="d"
        Title="SideTab Scroller"
        Height="720"
        Width="980"
        MinHeight="640"
        MinWidth="860"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#FFFFFF"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,0,0,1"
                Padding="32,24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="SideTab Scroller"
                               FontSize="30"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Edge / Chrome side tab wheel switching"
                               Foreground="{StaticResource MutedInkBrush}"
                               FontSize="14"
                               Margin="1,6,0,0" />
                </StackPanel>
                <CheckBox x:Name="EnabledSwitch"
                          Grid.Column="1"
                          Style="{StaticResource SwitchCheckBoxStyle}"
                          VerticalAlignment="Center"
                          Checked="SettingsControl_Changed"
                          Unchecked="SettingsControl_Changed"
                          Content="Enabled" />
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="32,28,32,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.25*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource SectionPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Detection Area"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Sidebar side"
                                       Foreground="{StaticResource MutedInkBrush}"
                                       Margin="0,18,0,8" />
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="SidebarAutoRadio"
                                             GroupName="SidebarSide"
                                             Content="Auto"
                                             Style="{StaticResource SegmentRadioStyle}"
                                             Checked="SideRadio_Checked" />
                                <RadioButton x:Name="SidebarLeftRadio"
                                             GroupName="SidebarSide"
                                             Content="Left"
                                             Style="{StaticResource SegmentRadioStyle}"
                                             Checked="SideRadio_Checked" />
                                <RadioButton x:Name="SidebarRightRadio"
                                             GroupName="SidebarSide"
                                             Content="Right"
                                             Style="{StaticResource SegmentRadioStyle}"
                                             Checked="SideRadio_Checked" />
                            </StackPanel>

                            <Grid Margin="0,24,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Sidebar width" Foreground="{StaticResource MutedInkBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ElementName=SidebarWidthSlider, Path=Value, StringFormat={}{0:0}px}"
                                           Foreground="{StaticResource MutedInkBrush}" />
                            </Grid>
                            <Slider x:Name="SidebarWidthSlider"
                                    Minimum="48"
                                    Maximum="260"
                                    TickFrequency="4"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="SettingsControl_Changed" />

                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Top inset" Foreground="{StaticResource MutedInkBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ElementName=TopInsetSlider, Path=Value, StringFormat={}{0:0}px}"
                                           Foreground="{StaticResource MutedInkBrush}" />
                            </Grid>
                            <Slider x:Name="TopInsetSlider"
                                    Minimum="0"
                                    Maximum="180"
                                    TickFrequency="2"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="SettingsControl_Changed" />

                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Bottom inset" Foreground="{StaticResource MutedInkBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ElementName=BottomInsetSlider, Path=Value, StringFormat={}{0:0}px}"
                                           Foreground="{StaticResource MutedInkBrush}" />
                            </Grid>
                            <Slider x:Name="BottomInsetSlider"
                                    Minimum="0"
                                    Maximum="120"
                                    TickFrequency="2"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="SettingsControl_Changed" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Behavior"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,18" />
                            <CheckBox x:Name="ReverseSwitch"
                                      Content="Reverse direction"
                                      Style="{StaticResource SwitchCheckBoxStyle}"
                                      Checked="SettingsControl_Changed"
                                      Unchecked="SettingsControl_Changed" />
                            <CheckBox x:Name="SwallowWheelSwitch"
                                      Content="Consume handled wheel events"
                                      Style="{StaticResource SwitchCheckBoxStyle}"
                                      Checked="SettingsControl_Changed"
                                      Unchecked="SettingsControl_Changed" />
                            <CheckBox x:Name="IgnoreModifiersSwitch"
                                      Content="Ignore when keyboard modifiers are pressed"
                                      Style="{StaticResource SwitchCheckBoxStyle}"
                                      Checked="SettingsControl_Changed"
                                      Unchecked="SettingsControl_Changed" />
                            <CheckBox x:Name="AutofocusSwitch"
                                      Content="Autofocus browser window"
                                      Style="{StaticResource SwitchCheckBoxStyle}"
                                      Checked="SettingsControl_Changed"
                                      Unchecked="SettingsControl_Changed" />
                            <CheckBox x:Name="RestoreFocusSwitch"
                                      Content="Restore previous focus"
                                      Style="{StaticResource SwitchCheckBoxStyle}"
                                      Checked="SettingsControl_Changed"
                                      Unchecked="SettingsControl_Changed" />

                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Focus delay" Foreground="{StaticResource MutedInkBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ElementName=FocusDelaySlider, Path=Value, StringFormat={}{0:0}ms}"
                                           Foreground="{StaticResource MutedInkBrush}" />
                            </Grid>
                            <Slider x:Name="FocusDelaySlider"
                                    Minimum="0"
                                    Maximum="120"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="SettingsControl_Changed" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource SectionPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Browser Targets"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBox x:Name="BrowserProcessesBox"
                                     Margin="0,18,0,0"
                                     MinHeight="96"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     BorderBrush="{StaticResource LineBrush}"
                                     Padding="12"
                                     TextChanged="BrowserProcessesBox_TextChanged" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Startup"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,18" />
                            <CheckBox x:Name="StartupSwitch"
                                      Content="Run at sign-in"
                                      Style="{StaticResource SwitchCheckBoxStyle}"
                                      Checked="StartupSwitch_Changed"
                                      Unchecked="StartupSwitch_Changed" />
                            <TextBlock x:Name="StartupStatusText"
                                       Foreground="{StaticResource MutedInkBrush}"
                                       FontSize="13" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Status"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="StatusText"
                                       Margin="0,16,0,0"
                                       Foreground="{StaticResource MutedInkBrush}" />
                            <TextBlock x:Name="LastActionText"
                                       Margin="0,10,0,0"
                                       Foreground="{StaticResource MutedInkBrush}" />
                            <TextBlock x:Name="ConfigPathText"
                                       Margin="0,10,0,0"
                                       Foreground="{StaticResource MutedInkBrush}" />
                            <WrapPanel Margin="0,22,0,0">
                                <Button Content="Open config"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,10,10"
                                        Click="OpenConfigButton_Click" />
                                <Button Content="Reset"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,10,10"
                                        Click="ResetButton_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
