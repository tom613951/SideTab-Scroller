<ui:FluentWindow x:Class="SideTabScroller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SideTabScroller"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="侧栏滚轮切换标签"
        Height="740"
        Width="1000"
        MinHeight="660"
        MinWidth="880"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        Icon="Assets/app.ico">
    <ui:FluentWindow.Resources>
        <ContextMenu x:Key="TrayContextMenu" Width="200">
            <!-- Custom Header MenuItem -->
            <MenuItem IsEnabled="False" Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                <MenuItem.Header>
                    <StackPanel Margin="0,2,0,2">
                        <TextBlock Text="侧栏滚轮切换标签" FontWeight="SemiBold" FontSize="12.5" />
                        <TextBlock Text="正在监听" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0" />
                    </StackPanel>
                </MenuItem.Header>
            </MenuItem>
            
            <Separator />
            
            <MenuItem Header="打开设置" Click="TraySettings_Click">
                <MenuItem.Icon>
                    <ui:SymbolIcon Symbol="Settings24" />
                </MenuItem.Icon>
            </MenuItem>
            
            <MenuItem Header="停用" Click="TrayToggle_Click">
                <MenuItem.Icon>
                    <ui:SymbolIcon Symbol="Pause24" />
                </MenuItem.Icon>
            </MenuItem>
            
            <Separator />
            
            <MenuItem Header="退出" Click="TrayExit_Click" Foreground="#C42B1C" FontWeight="SemiBold">
                <MenuItem.Icon>
                    <ui:SymbolIcon Symbol="Dismiss24" Foreground="#C42B1C" />
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>
    </ui:FluentWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom Fluent TitleBar -->
        <ui:TitleBar Grid.Row="0"
                     Title="侧栏滚轮切换标签"
                     Icon="Assets/app.ico" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="32,24,32,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                
                <!-- Header Card with Master Toggle -->
                <ui:Card Grid.Row="0" Margin="0,0,0,24" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="侧栏滚轮切换标签服务"
                                       FontSize="20"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="当鼠标悬停在 Chromium 内核浏览器的垂直标签栏上时，滚动滚轮可快速切换标签页。"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       FontSize="13"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                        <ui:ToggleSwitch x:Name="EnabledSwitch"
                                         Grid.Column="1"
                                         VerticalAlignment="Center"
                                         Checked="SettingsControl_Changed"
                                         Unchecked="SettingsControl_Changed"
                                         Content="服务状态" />
                    </Grid>
                </ui:Card>

                <!-- Settings Columns Grid -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.25*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left Column: Sensing and Behaviors -->
                    <StackPanel Grid.Column="0">
                        
                        <!-- Sensing Area Settings Card -->
                        <ui:Card Margin="0,0,0,20" Padding="20">
                            <StackPanel>
                                <TextBlock Text="感应区域"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,16" />

                                <!-- Sidebar Side Selector -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="触发侧边" FontWeight="Medium" />
                                        <TextBlock Text="触发切换标签页的鼠标感应区侧边" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <RadioButton x:Name="SidebarSideLeftRadio" Content="左侧" Margin="0,0,8,0" Checked="SidebarSideRadio_Checked" />
                                        <RadioButton x:Name="SidebarSideRightRadio" Content="右侧" Margin="0,0,8,0" Checked="SidebarSideRadio_Checked" />
                                        <RadioButton x:Name="SidebarSideAutoRadio" Content="双侧/自动" Checked="SidebarSideRadio_Checked" />
                                    </StackPanel>
                                </Grid>

                                <Separator Margin="0,8,0,16" Background="{DynamicResource CardStrokeColorDefaultBrush}" />
                                <Grid Margin="0,0,0,16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Row="0" VerticalAlignment="Center">
                                        <TextBlock Text="侧边栏宽度" FontWeight="Medium" />
                                        <TextBlock Text="触发切换的侧栏鼠标感应区域宽度（像素）" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding ElementName=SidebarWidthSlider, Path=Value, StringFormat={}{0:0}px}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                                    <Slider x:Name="SidebarWidthSlider"
                                               Grid.Row="1" Grid.ColumnSpan="2"
                                               Margin="0,10,0,0"
                                               Minimum="48"
                                               Maximum="260"
                                               TickFrequency="4"
                                               IsSnapToTickEnabled="True"
                                               ValueChanged="SettingsControl_Changed" />
                                </Grid>

                                <Separator Margin="0,8,0,16" Background="{DynamicResource CardStrokeColorDefaultBrush}" />

                                <!-- Top Inset Slider -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Row="0" VerticalAlignment="Center">
                                        <TextBlock Text="顶部避让" FontWeight="Medium" />
                                        <TextBlock Text="忽略顶部特定高度的滑轮动作，防止干扰标签页操作" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding ElementName=TopInsetSlider, Path=Value, StringFormat={}{0:0}px}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                                    <Slider x:Name="TopInsetSlider"
                                               Grid.Row="1" Grid.ColumnSpan="2"
                                               Margin="0,10,0,0"
                                               Minimum="0"
                                               Maximum="180"
                                               TickFrequency="2"
                                               IsSnapToTickEnabled="True"
                                               ValueChanged="SettingsControl_Changed" />
                                </Grid>

                                <Separator Margin="0,8,0,16" Background="{DynamicResource CardStrokeColorDefaultBrush}" />

                                <!-- Bottom Inset Slider -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Row="0" VerticalAlignment="Center">
                                        <TextBlock Text="底部避让" FontWeight="Medium" />
                                        <TextBlock Text="忽略底部特定高度的滑轮动作" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding ElementName=BottomInsetSlider, Path=Value, StringFormat={}{0:0}px}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                                    <Slider x:Name="BottomInsetSlider"
                                               Grid.Row="1" Grid.ColumnSpan="2"
                                               Margin="0,10,0,0"
                                               Minimum="0"
                                               Maximum="120"
                                               TickFrequency="2"
                                               IsSnapToTickEnabled="True"
                                               ValueChanged="SettingsControl_Changed" />
                                </Grid>
                            </StackPanel>
                        </ui:Card>

                        <!-- Behaviors Settings Card -->
                        <ui:Card Margin="0,0,0,20" Padding="20">
                            <StackPanel>
                                <TextBlock Text="行为与功能"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,16" />

                                <!-- Shortcut Mode -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="切换快捷键" FontWeight="Medium" />
                                        <TextBlock Text="模拟切换标签页所发送的键盘快捷键组合" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <RadioButton x:Name="ShortcutCtrlTabRadio" Content="Ctrl+Tab" Margin="0,0,8,0" Checked="ShortcutModeRadio_Checked" />
                                        <RadioButton x:Name="ShortcutCtrlPageRadio" Content="Ctrl+Page" Checked="ShortcutModeRadio_Checked" />
                                    </StackPanel>
                                </Grid>

                                <Separator Margin="0,8,0,16" Background="{DynamicResource CardStrokeColorDefaultBrush}" />

                                <!-- Reverse Direction -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="反转滚动方向" FontWeight="Medium" />
                                        <TextBlock Text="颠倒滚轮向上/向下滚动时的标签页切换顺序" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <ui:ToggleSwitch x:Name="ReverseSwitch" Grid.Column="1" VerticalAlignment="Center" Checked="SettingsControl_Changed" Unchecked="SettingsControl_Changed" />
                                </Grid>

                                <!-- Swallow Wheel -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="拦截已处理的滚轮事件" FontWeight="Medium" />
                                        <TextBlock Text="拦截并吞噬已被处理的滑轮消息，防止底部网页随之滚动" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <ui:ToggleSwitch x:Name="SwallowWheelSwitch" Grid.Column="1" VerticalAlignment="Center" Checked="SettingsControl_Changed" Unchecked="SettingsControl_Changed" />
                                </Grid>

                                <!-- Ignore Modifiers -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="修饰键忽略" FontWeight="Medium" />
                                        <TextBlock Text="按住 Ctrl / Alt / Shift / Win 等修饰键时忽略滚轮动作" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <ui:ToggleSwitch x:Name="IgnoreModifiersSwitch" Grid.Column="1" VerticalAlignment="Center" Checked="SettingsControl_Changed" Unchecked="SettingsControl_Changed" />
                                </Grid>

                                <!-- Autofocus Browser -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="自动聚焦浏览器窗口" FontWeight="Medium" />
                                        <TextBlock Text="滚动时自动将焦点转移到浏览器窗口" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <ui:ToggleSwitch x:Name="AutofocusSwitch" Grid.Column="1" VerticalAlignment="Center" Checked="SettingsControl_Changed" Unchecked="SettingsControl_Changed" />
                                </Grid>

                                <!-- Restore Focus -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="恢复原窗口焦点" FontWeight="Medium" />
                                        <TextBlock Text="滚动结束后尝试将活动焦点恢复到切换前的窗口" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <ui:ToggleSwitch x:Name="RestoreFocusSwitch" Grid.Column="1" VerticalAlignment="Center" Checked="SettingsControl_Changed" Unchecked="SettingsControl_Changed" />
                                </Grid>

                                <Separator Margin="0,8,0,16" Background="{DynamicResource CardStrokeColorDefaultBrush}" />

                                <!-- Focus Delay Slider -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Row="0" VerticalAlignment="Center">
                                        <TextBlock Text="聚焦等待延迟" FontWeight="Medium" />
                                        <TextBlock Text="强制聚焦浏览器窗口后发送快捷键的缓冲延迟时间（毫秒）" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding ElementName=FocusDelaySlider, Path=Value, StringFormat={}{0:0}ms}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                                    <Slider x:Name="FocusDelaySlider"
                                               Grid.Row="1" Grid.ColumnSpan="2"
                                               Margin="0,10,0,0"
                                               Minimum="0"
                                               Maximum="120"
                                               TickFrequency="1"
                                               IsSnapToTickEnabled="True"
                                               ValueChanged="SettingsControl_Changed" />
                                </Grid>
                            </StackPanel>
                        </ui:Card>
                    </StackPanel>

                    <!-- Right Column: Browser, Startup and Status -->
                    <StackPanel Grid.Column="2">
                        
                        <!-- Browser Processes Card -->
                        <ui:Card Margin="0,0,0,20" Padding="20">
                            <StackPanel>
                                <TextBlock Text="浏览器进程" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <TextBlock Text="在此处添加受感应的浏览器进程列表（每行一个，不要包含 .exe 后缀）：" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,12" />
                                <ui:TextBox x:Name="BrowserProcessesBox"
                                             MinHeight="120"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             Padding="10"
                                             TextChanged="BrowserProcessesBox_TextChanged" />
                            </StackPanel>
                        </ui:Card>

                        <!-- Startup Settings Card -->
                        <ui:Card Margin="0,0,0,20" Padding="20">
                            <StackPanel>
                                <TextBlock Text="开机启动" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="登录后自动运行" FontWeight="Medium" />
                                        <TextBlock x:Name="StartupStatusText" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <ui:ToggleSwitch x:Name="StartupSwitch" Grid.Column="1" VerticalAlignment="Center" Checked="StartupSwitch_Changed" Unchecked="StartupSwitch_Changed" />
                                </Grid>
                            </StackPanel>
                        </ui:Card>

                        <!-- Status and Maintenance Card -->
                        <ui:Card Margin="0,0,0,20" Padding="20">
                            <StackPanel>
                                <TextBlock Text="服务状态与配置" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16" />
                                <StackPanel Margin="0,0,0,20">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon Symbol="Pulse24" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                                        <TextBlock x:Name="StatusText" Grid.Column="1" FontWeight="Medium" VerticalAlignment="Center" />
                                    </Grid>
                                    
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon Symbol="History24" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock x:Name="LastActionText" Grid.Column="1" FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                    </Grid>
                                    
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon Symbol="Settings24" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock x:Name="ConfigPathText" Grid.Column="1" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    </Grid>
                                </StackPanel>
                                <WrapPanel>
                                    <ui:Button Content="打开配置文件"
                                               Appearance="Secondary"
                                               Icon="{ui:SymbolIcon FolderOpen24}"
                                               Margin="0,0,8,8"
                                               Click="OpenConfigButton_Click" />
                                    <ui:Button Content="重置默认参数"
                                               Appearance="Caution"
                                               Icon="{ui:SymbolIcon History24}"
                                               Margin="0,0,0,8"
                                               Click="ResetButton_Click" />
                                </WrapPanel>
                            </StackPanel>
                        </ui:Card>
                        
                    </StackPanel>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
