<Window x:Class="SideTabScroller.TrayMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="托盘菜单"
        Width="238"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        Deactivated="Window_Deactivated">
    <Window.Resources>
        <Style x:Key="TrayMenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EDF2F7" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#E2E8F0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="10"
            Background="#FAFAFA"
            BorderBrush="#E5E7EB"
            BorderThickness="1"
            CornerRadius="10"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24"
                              ShadowDepth="8"
                              Direction="270"
                              Color="#55000000"
                              Opacity="0.24" />
        </Border.Effect>

        <StackPanel Margin="6">
            <Border Padding="12,10,12,8">
                <StackPanel>
                    <TextBlock Text="侧栏滚轮切换标签"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#111827" />
                    <TextBlock x:Name="StatusText"
                               Margin="0,4,0,0"
                               FontSize="12"
                               Foreground="#64748B" />
                </StackPanel>
            </Border>

            <Border Height="1" Background="#E5E7EB" Margin="6,2,6,6" />

            <Button Style="{StaticResource TrayMenuButtonStyle}" Click="SettingsButton_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="&#xE713;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Foreground="#334155" />
                    <TextBlock Grid.Column="1"
                               Text="打开设置"
                               VerticalAlignment="Center"
                               Foreground="#111827" />
                </Grid>
            </Button>

            <Button Style="{StaticResource TrayMenuButtonStyle}" Click="ToggleButton_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ToggleGlyph"
                               Text="&#xE73E;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Foreground="#334155" />
                    <TextBlock x:Name="ToggleText"
                               Grid.Column="1"
                               Text="停用"
                               VerticalAlignment="Center"
                               Foreground="#111827" />
                </Grid>
            </Button>

            <Border Height="1" Background="#E5E7EB" Margin="6,6,6,6" />

            <Button Style="{StaticResource TrayMenuButtonStyle}" Click="ExitButton_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="&#xE8BB;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Foreground="#B91C1C" />
                    <TextBlock Grid.Column="1"
                               Text="退出"
                               VerticalAlignment="Center"
                               Foreground="#111827" />
                </Grid>
            </Button>
        </StackPanel>
    </Border>
</Window>
