<Application x:Class="SideTabScroller.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SideTabScroller"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <!-- Color and brush definitions matching WinUI 3 styles for fallback/custom UI elements -->
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FAF9F8" />
            <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="LineBrush" Color="#E5E5E5" />
            <SolidColorBrush x:Key="InkBrush" Color="#1C1C1C" />
            <SolidColorBrush x:Key="MutedInkBrush" Color="#5E5E5E" />
            <SolidColorBrush x:Key="AccentBrush" Color="#0066B3" />
            <SolidColorBrush x:Key="AccentHoverBrush" Color="#005290" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
